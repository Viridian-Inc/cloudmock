{
  "domains": [
    {
      "name": "Core Platform",
      "services": ["identity", "organizations", "membership", "enterprise"]
    },
    {
      "name": "Scheduling",
      "services": ["attendance", "calendar", "compliance", "attendancePolicy"]
    },
    {
      "name": "Commerce",
      "services": ["billing", "order", "stripeWebhook"]
    },
    {
      "name": "Engagement",
      "services": ["notifications", "integrations", "invitation", "lms"]
    },
    {
      "name": "Platform Services",
      "services": ["bff", "graphql", "calendar-service", "analytics", "audit", "apiKey"]
    },
    {
      "name": "User Management",
      "services": ["userAdmin", "userGroup", "userMetadata", "sso", "accessControl"]
    }
  ],
  "userFacingOverrides": {
    "bff": true,
    "graphql": true
  },
  "routing": {
    "bff": {
      "local": "http://localhost:3202",
      "dev": "https://bff.dev.autotend.io"
    },
    "graphql": {
      "local": "http://localhost:4000",
      "dev": "https://graphql.dev.autotend.io"
    }
  }
}
