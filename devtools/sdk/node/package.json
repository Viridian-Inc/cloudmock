{
  "name": "@cloudmock/node",
  "version": "0.1.0",
  "description": "CloudMock devtools SDK for Node.js — captures HTTP requests, console logs, and errors",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0"
  },
  "keywords": [
    "cloudmock",
    "devtools",
    "debugging",
    "observability"
  ],
  "license": "Apache-2.0"
}
