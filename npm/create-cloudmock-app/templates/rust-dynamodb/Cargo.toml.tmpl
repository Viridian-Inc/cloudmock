[package]
name = "{{PROJECT_NAME}}"
version = "0.1.0"
edition = "2021"

[dependencies]
axum = "0.7"
aws-config = "1.5"
aws-sdk-dynamodb = "1.50"
serde = { version = "1", features = ["derive"] }
serde_json = "1"
tokio = { version = "1", features = ["full"] }
tracing = "0.1"
tracing-subscriber = "0.3"

[dev-dependencies]
cloudmock = "1.0"
axum-test = "15"
tokio = { version = "1", features = ["full"] }
