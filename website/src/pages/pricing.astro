---
const title = "Pricing -- CloudMock";
const description = "Free for local development. Hosted endpoints for teams.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <style>
      @import "../styles/homepage.css";
      @import "../styles/pricing.css";
    </style>
  </head>
  <body>
    <!-- Navigation -->
    <nav class="nav">
      <div class="nav-inner">
        <a href="/" class="nav-logo">CloudMock</a>
        <ul class="nav-links">
          <li><a href="/docs/">Docs</a></li>
          <li><a href="/pricing">Pricing</a></li>
          <li>
            <a
              href="https://github.com/Viridian-Inc/cloudmock"
              target="_blank"
              rel="noopener noreferrer">GitHub</a
            >
          </li>
        </ul>
      </div>
    </nav>

    <!-- Pricing Hero -->
    <section class="pricing-hero">
      <div class="container">
        <h1>Pricing</h1>
        <p>
          Free locally. Pay only for what you use in the cloud.
        </p>
      </div>
    </section>

    <!-- Tier Cards -->
    <section style="padding-top: 0;">
      <div class="container">
        <div class="pricing-grid">
          <!-- Local (Free) -->
          <div class="tier-card">
            <h2 class="tier-name">Local</h2>
            <p class="tier-desc">
              Run on your machine. No account, no limits.
            </p>
            <div class="tier-price">
              <span class="amount">$0</span>
              <span class="period">forever</span>
            </div>
            <ul class="tier-features">
              <li>
                <span class="check">&#10003;</span>
                <span>100 AWS services</span>
              </li>
              <li>
                <span class="check">&#10003;</span>
                <span>Unlimited requests</span>
              </li>
              <li>
                <span class="check">&#10003;</span>
                <span>Built-in devtools</span>
              </li>
              <li>
                <span class="check">&#10003;</span>
                <span>State snapshots</span>
              </li>
              <li>
                <span class="check">&#10003;</span>
                <span>Chaos engineering</span>
              </li>
              <li>
                <span class="dash">--</span>
                <span>No hosted endpoint</span>
              </li>
              <li>
                <span class="check">&#10003;</span>
                <span>Community support</span>
              </li>
            </ul>
            <div class="tier-cta">
              <a
                href="/docs/getting-started/installation/"
                class="btn-primary">Get Started</a
              >
            </div>
          </div>

          <!-- Hosted (Pay-as-you-go) -->
          <div class="tier-card featured">
            <span class="tier-badge">For Teams</span>
            <h2 class="tier-name">Hosted</h2>
            <p class="tier-desc">
              Cloud endpoints for CI/CD, staging, and shared environments. Pay per request.
            </p>
            <div class="tier-price">
              <span class="amount">$0.50</span>
              <span class="period">per 10K requests</span>
            </div>
            <ul class="tier-features">
              <li>
                <span class="check">&#10003;</span>
                <span>1,000 free requests/mo</span>
              </li>
              <li>
                <span class="check">&#10003;</span>
                <span>100 AWS services</span>
              </li>
              <li>
                <span class="check">&#10003;</span>
                <span>Hosted endpoint: yourteam.cloudmock.app</span>
              </li>
              <li>
                <span class="check">&#10003;</span>
                <span>Multiple apps per org</span>
              </li>
              <li>
                <span class="check">&#10003;</span>
                <span>API keys with RBAC</span>
              </li>
              <li>
                <span class="check">&#10003;</span>
                <span>Team management (SSO)</span>
              </li>
              <li>
                <span class="check">&#10003;</span>
                <span>HIPAA-ready audit logs</span>
              </li>
              <li>
                <span class="check">&#10003;</span>
                <span>Usage dashboard</span>
              </li>
              <li>
                <span class="check">&#10003;</span>
                <span>Email support</span>
              </li>
            </ul>
            <div class="tier-cta">
              <a
                href="https://app.cloudmock.app/sign-up"
                class="btn-primary">Start Free</a
              >
              <p class="tier-cta-note">
                1,000 requests free every month. No credit card required.
              </p>
            </div>
          </div>

          <!-- Enterprise -->
          <div class="tier-card">
            <h2 class="tier-name">Enterprise</h2>
            <p class="tier-desc">
              Dedicated infrastructure, BAA, and volume pricing.
            </p>
            <div class="tier-price">
              <span class="amount">Custom</span>
            </div>
            <ul class="tier-features">
              <li>
                <span class="check">&#10003;</span>
                <span>Everything in Hosted</span>
              </li>
              <li>
                <span class="check">&#10003;</span>
                <span>Dedicated CloudMock instances</span>
              </li>
              <li>
                <span class="check">&#10003;</span>
                <span>HIPAA BAA</span>
              </li>
              <li>
                <span class="check">&#10003;</span>
                <span>Volume pricing</span>
              </li>
              <li>
                <span class="check">&#10003;</span>
                <span>Custom data retention</span>
              </li>
              <li>
                <span class="check">&#10003;</span>
                <span>SSO / SAML</span>
              </li>
              <li>
                <span class="check">&#10003;</span>
                <span>Priority support + SLA</span>
              </li>
            </ul>
            <div class="tier-cta">
              <a
                href="mailto:sales@viridian.dev"
                class="btn-primary">Contact Sales</a
              >
            </div>
          </div>
        </div>

        <!-- Cost calculator -->
        <div style="text-align:center; margin:3rem 0 0; padding:1.5rem; border:1px solid var(--border-muted, #333); border-radius:8px; max-width:600px; margin-left:auto; margin-right:auto;">
          <p style="margin:0 0 0.5rem; font-size:1.1rem; font-weight:600;">How much will it cost?</p>
          <p style="margin:0; color:#999; font-size:0.9rem;">
            10K requests/mo = <strong style="color:#52b788;">$0.50</strong> &nbsp;|&nbsp;
            100K requests/mo = <strong style="color:#52b788;">$4.95</strong> &nbsp;|&nbsp;
            1M requests/mo = <strong style="color:#52b788;">$49.95</strong>
          </p>
          <p style="margin:0.5rem 0 0; color:#666; font-size:0.8rem;">First 1,000 requests free every month</p>
        </div>
      </div>
    </section>

    <!-- Comparison Table -->
    <section class="comparison-section">
      <div class="container">
        <div class="section-header-center">
          <h2 class="section-title">Compare plans</h2>
        </div>
        <div class="comparison-table-wrap">
          <table class="comparison-table">
            <thead>
              <tr>
                <th></th>
                <th>Local</th>
                <th class="highlight-col">Hosted</th>
                <th>Enterprise</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Price</td>
                <td>$0</td>
                <td class="highlight-col">$0.50 / 10K reqs</td>
                <td>Custom</td>
              </tr>
              <tr>
                <td>AWS services</td>
                <td>100</td>
                <td class="highlight-col">100</td>
                <td>100</td>
              </tr>
              <tr>
                <td>Hosted endpoint</td>
                <td>No</td>
                <td class="highlight-col">yourteam.cloudmock.app</td>
                <td>yourteam.cloudmock.app</td>
              </tr>
              <tr>
                <td>Infrastructure</td>
                <td>Your machine</td>
                <td class="highlight-col">Shared</td>
                <td>Dedicated</td>
              </tr>
              <tr>
                <td>Team management</td>
                <td>No</td>
                <td class="highlight-col">Yes (SSO)</td>
                <td>Yes (SAML)</td>
              </tr>
              <tr>
                <td>Audit log</td>
                <td>No</td>
                <td class="highlight-col">Yes</td>
                <td>Yes + export</td>
              </tr>
              <tr>
                <td>HIPAA</td>
                <td>No</td>
                <td class="highlight-col">Audit logs</td>
                <td>Full BAA</td>
              </tr>
              <tr>
                <td>Support</td>
                <td>Community</td>
                <td class="highlight-col">Email</td>
                <td>Priority + SLA</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="faq-section">
      <div class="container">
        <div class="section-header-center">
          <h2 class="section-title">Questions</h2>
        </div>
        <div class="faq-grid">
          <div class="faq-item">
            <h3>Is the local CLI really free?</h3>
            <p>
              Yes. CloudMock is free for local development and internal use
              under the Business Source License. No usage limits. No account
              required. Converts to Apache 2.0 in 2030.
            </p>
          </div>
          <div class="faq-item">
            <h3>What are hosted endpoints?</h3>
            <p>
              Sign up and you get a hosted CloudMock endpoint at
              yourteam.cloudmock.app. Point your AWS SDK at it from CI/CD,
              staging, or anywhere your team needs shared AWS emulation.
            </p>
          </div>
          <div class="faq-item">
            <h3>How does billing work?</h3>
            <p>
              Pay-as-you-go. First 1,000 requests per month are free.
              After that, $0.50 per 10,000 requests. No upfront commitment.
              Add a credit card when you're ready to go beyond the free tier.
            </p>
          </div>
          <div class="faq-item">
            <h3>Can I self-host?</h3>
            <p>
              Yes. The binary runs anywhere -- your laptop, a VM, a container.
              The hosted plans add managed infrastructure and support.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="site-footer">
      <div class="footer-inner">
        <span class="footer-copy">CloudMock</span>
        <ul class="footer-links">
          <li><a href="/docs/">Docs</a></li>
          <li><a href="/pricing">Pricing</a></li>
          <li>
            <a
              href="https://github.com/Viridian-Inc/cloudmock"
              target="_blank"
              rel="noopener noreferrer">GitHub</a
            >
          </li>
        </ul>
      </div>
    </footer>
  </body>
</html>
